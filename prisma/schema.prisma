generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  SUPER_ADMIN
  MANDAL_ADMIN
  PANCHAYAT_ADMIN
  BOOTH_ADMIN
}

model Party {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  abbrev    String      @unique
  users     User[]
  marks     VoterMark[] 
  
  @@map("party")
}

model Constituency {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  panchayats Panchayat[]
  users      User[]

  @@map("constituency")
}

model Panchayat {
  id             Int          @id @default(autoincrement())
  name           String
  constituencyId Int
  constituency   Constituency @relation(fields: [constituencyId], references: [id])
  booths          Booth[]
  users          User[]

  @@map("panchayat")
}

model Booth {
  id          Int       @id @default(autoincrement())
  number      Int
  name        String?
  panchayatId Int
  panchayat   Panchayat @relation(fields: [panchayatId], references: [id])
  totalVoters Int       @default(0) 
  voters      Voter[]
  users       User[]

  @@map("booth")
}

model User {
  id             Int           @id @default(autoincrement())
  username       String        @unique
  email          String        @unique
  passwordHash   String
  name           String
  role           Role
  partyId        Int?
  party          Party?        @relation(fields: [partyId], references: [id])
  constituencyId Int?
  constituency   Constituency? @relation(fields: [constituencyId], references: [id])
  panchayatId    Int?
  panchayat      Panchayat?    @relation(fields: [panchayatId], references: [id])
  boothId         Int?
  booth           Booth?         @relation(fields: [boothId], references: [id])
  marksMade      VoterMark[]   

  @@map("user")
}

model Voter {
  id           Int         @id @default(autoincrement())
  serialNumber Int         
  boothId       Int
  booth         Booth        @relation(fields: [boothId], references: [id])
  marks        VoterMark[]
  
  @@unique([serialNumber, boothId])
  @@map("voter")
}

model VoterMark {
  id        Int      @id @default(autoincrement())
  voterId   Int
  voter     Voter    @relation(fields: [voterId], references: [id])
  partyId   Int
  party     Party    @relation(fields: [partyId], references: [id])
  markedBy  Int
  user      User     @relation(fields: [markedBy], references: [id])
  hasVoted  Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@unique([voterId, partyId]) 
  @@map("votermark")
}
